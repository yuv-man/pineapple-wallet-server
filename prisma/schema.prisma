generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String?
  name            String
  avatar          String?
  displayCurrency String    @default("USD") // User's preferred currency for displaying totals
  provider        String?   // 'local', 'google', 'github'
  providerId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  portfolios    Portfolio[]
  sharedWith    PortfolioShare[] @relation("SharedWithUser")
  refreshTokens RefreshToken[]

  // Property relations
  properties         Property[]
  propertySharedWith PropertyShare[] @relation("SharedWithUserProperty")
  customCategories   PropertyCategory[]

  liabilities       Liability[]
  netWorthSnapshots NetWorthSnapshot[]
  assetsAdded       Asset[]            @relation("AssetAddedBy")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Portfolio {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets      Asset[]
  shares      PortfolioShare[]

  @@map("portfolios")
}

model PortfolioShare {
  id               String      @id @default(uuid())
  portfolioId      String
  portfolio        Portfolio   @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  sharedWithUserId String
  sharedWithUser   User        @relation("SharedWithUser", fields: [sharedWithUserId], references: [id], onDelete: Cascade)
  permission       Permission  @default(VIEW)
  status           ShareStatus @default(PENDING)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([portfolioId, sharedWithUserId])
  @@map("portfolio_shares")
}

enum Permission {
  VIEW
  EDIT
}

enum ShareStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Asset {
  id            String    @id @default(uuid())
  portfolioId   String
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  type          AssetType
  name          String
  value         Decimal   @db.Decimal(20, 2)
  currency      String    @default("USD")
  notes         String?
  details       Json?     // Type-specific details stored as JSON
  addedByUserId String?
  addedBy       User?     @relation("AssetAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  valueHistory AssetValueHistory[]

  @@map("assets")
}

enum AssetType {
  BANK_ACCOUNT
  REAL_ESTATE
  CRYPTO
  STOCK
  INVESTMENT
}

model AssetValueHistory {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  value     Decimal  @db.Decimal(20, 2)
  recordedAt DateTime @default(now())

  @@map("asset_value_history")
}

// ==================== PROPERTY MODELS ====================

enum TransactionType {
  EXPENSE
  PROFIT
}

enum CategoryType {
  EXPENSE
  PROFIT
}

enum PropertyType {
  APARTMENT
  HOUSE
  LAND
  COMMERCIAL
  OTHER
}

enum SizeUnit {
  SQM
  SQFT
}

model Property {
  id          String   @id @default(uuid())
  name        String
  address     String?
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Valuation fields
  propertyType           PropertyType?
  size                   Decimal?      @db.Decimal(20, 2)
  sizeUnit               SizeUnit?
  country                String?
  city                   String?
  estimatedValue         Decimal?      @db.Decimal(20, 2)
  estimatedValueCurrency String?
  estimatedValueDate     DateTime?
  valuationSource        String?       // 'zillow', 'fallback', etc.

  transactions PropertyTransaction[]
  shares       PropertyShare[]

  @@map("properties")
}

model PropertyCategory {
  id        String       @id @default(uuid())
  name      String
  type      CategoryType
  isSystem  Boolean      @default(false)
  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  transactions PropertyTransaction[]

  @@unique([name, type, userId])
  @@map("property_categories")
}

model PropertyTransaction {
  id          String           @id @default(uuid())
  propertyId  String
  property    Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  categoryId  String
  category    PropertyCategory @relation(fields: [categoryId], references: [id])
  type        TransactionType
  amount      Decimal          @db.Decimal(20, 2)
  currency    String           @default("USD")
  date        DateTime
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("property_transactions")
}

model PropertyShare {
  id               String      @id @default(uuid())
  propertyId       String
  property         Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sharedWithUserId String
  sharedWithUser   User        @relation("SharedWithUserProperty", fields: [sharedWithUserId], references: [id], onDelete: Cascade)
  permission       Permission  @default(VIEW)
  status           ShareStatus @default(PENDING)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([propertyId, sharedWithUserId])
  @@map("property_shares")
}

// ==================== LIABILITIES & NET WORTH HISTORY ====================

enum LiabilityType {
  CREDIT_CARD
  MORTGAGE
  STUDENT_LOAN
  PERSONAL_LOAN
  AUTO_LOAN
  HOME_EQUITY_LOAN
  MEDICAL_DEBT
  OTHER
}

model Liability {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           LiabilityType
  name           String
  balance        Decimal       @db.Decimal(20, 2)
  currency       String        @default("USD")
  interestRate   Decimal?      @db.Decimal(5, 4)
  minimumPayment Decimal?      @db.Decimal(20, 2)
  dueDate        DateTime?
  notes          String?
  details        Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  balanceHistory LiabilityBalanceHistory[]

  @@map("liabilities")
}

model LiabilityBalanceHistory {
  id          String    @id @default(uuid())
  liabilityId String
  liability   Liability @relation(fields: [liabilityId], references: [id], onDelete: Cascade)
  balance     Decimal   @db.Decimal(20, 2)
  recordedAt  DateTime  @default(now())

  @@map("liability_balance_history")
}

model NetWorthSnapshot {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalAssets      Decimal  @db.Decimal(20, 2)
  totalLiabilities Decimal  @db.Decimal(20, 2)
  netWorth         Decimal  @db.Decimal(20, 2)
  currency         String   @default("USD")
  snapshotDate     DateTime @default(now())

  @@unique([userId, snapshotDate])
  @@index([userId, snapshotDate])
  @@map("net_worth_snapshots")
}
